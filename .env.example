APP_NAME=Likert Survey Platform

# DATABASE_URL has higher priority if provided.
# Example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/scale_db

PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=scale_db

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=720
PURGE_GRACE_DAYS=7
EXPORT_DIR=./outputs
SQL_ECHO=false
